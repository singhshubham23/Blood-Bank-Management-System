# BloodBank Backend — Environment Variables
# Copy this file to .env and fill in the values

PORT=5000

# MongoDB connection string (use MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=bloodbank

# JWT — generate a strong random secret (min 64 chars)
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# Allowed frontend origin (CORS)
FRONTEND_URL=https://your-app.vercel.app

# Seed admin credentials (used only during initial seeding)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123

# Seed organisation credentials
SEED_ORG_EMAIL=org@example.com
SEED_ORG_PASSWORD=Org@123

# Seed hospital credentials
SEED_HOSP_EMAIL=hospital@example.com
SEED_HOSP_PASSWORD=Hosp@123
